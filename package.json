{
  "name": "zoom-chapter-splitter",
  "version": "1.0.0",
  "description": "AI-powered Zoom recording chapter splitter for macOS",
  "main": "./out/main/index.js",
  "author": "Zoom Chapter Splitter",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-builder --mac --config",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "ffmpeg-ffprobe-static": "^6.1.2-rc.1",
    "fluent-ffmpeg": "^2.1.3",
    "node-webvtt": "^1.9.4",
    "openai": "^4.77.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.14",
    "@types/react-dom": "^18.3.4",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "typescript": "^5.7.2",
    "vite": "^7.3.2"
  },
  "build": {
    "appId": "com.zoomchaptersplitter.app",
    "productName": "Zoom Chapter Splitter",
    "mac": {
      "category": "public.app-category.video",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": {
        "teamId": "${env.APPLE_TEAM_ID}"
      }
    },
    "files": [
      "out/**/*",
      "!node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "node_modules/ffmpeg-ffprobe-static/ffmpeg",
        "to": "ffmpeg"
      },
      {
        "from": "node_modules/ffmpeg-ffprobe-static/ffprobe",
        "to": "ffprobe"
      }
    ],
    "asarUnpack": [
      "**/node_modules/ffmpeg-ffprobe-static/**"
    ]
  }
}
