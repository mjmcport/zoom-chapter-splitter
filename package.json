{
  "name": "zoom-chapter-splitter",
  "version": "1.0.0",
  "description": "AI-powered Zoom recording chapter splitter for macOS",
  "main": "./out/main/index.js",
  "author": "Zoom Chapter Splitter",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-builder --mac --config",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5",
    "fluent-ffmpeg": "^2.1.3",
    "ffmpeg-static": "^5.2.0",
    "node-webvtt": "^1.9.4",
    "openai": "^4.77.0",
    "@anthropic-ai/sdk": "^0.32.1",
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "vite": "^5.4.11",
    "typescript": "^5.7.2",
    "@types/react": "^18.3.14",
    "@types/react-dom": "^18.3.4",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.10.2",
    "@vitejs/plugin-react": "^4.3.4"
  },
  "build": {
    "appId": "com.zoomchaptersplitter.app",
    "productName": "Zoom Chapter Splitter",
    "mac": {
      "category": "public.app-category.video",
      "target": ["dmg"],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "files": [
      "out/**/*",
      "!node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "node_modules/ffmpeg-static/ffmpeg",
        "to": "ffmpeg"
      }
    ],
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**",
      "**/node_modules/keytar/**"
    ]
  }
}
